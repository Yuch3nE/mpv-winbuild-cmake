#!/bin/bash
export O_PATH="$PATH"
export PATH="@CMAKE_INSTALL_PREFIX@/bin:@RUSTUP_LOCATION@/.cargo/bin:$PATH"
export PKG_CONFIG="pkgconf --static"
export PKG_CONFIG_LIBDIR="@MINGW_INSTALL_PREFIX@/lib/pkgconfig"
export RUSTUP_HOME="@RUSTUP_LOCATION@/.rustup"
export CARGO_HOME="@RUSTUP_LOCATION@/.cargo"
export LD_PRELOAD="@MALLOC@"
export CCACHE_DIR="@MINGW_INSTALL_PREFIX@/ccache"
export LLVM_PROFILE_FILE="/dev/null"
# disable profraw output by default, ensure that only clang and lld can explicitly enable profraw output by wrapper

git_am_forward() {
	local patch_file

	for patch_file in "$@"; do
		if [[ ! -f "$patch_file" ]]; then
			echo "Missing patch file: $patch_file" >&2
			return 1
		fi

		if git apply --check --reverse "$patch_file" >/dev/null 2>&1; then
			continue
		fi

		if ! git apply --check "$patch_file" >/dev/null 2>&1; then
			echo "Patch is neither applicable nor already applied: $patch_file" >&2
			return 1
		fi

		if ! git am --3way "$patch_file"; then
			git am --abort >/dev/null 2>&1 || true
			return 1
		fi
	done
}

patch_forward() {
	local patch_args=()
	local patch_file

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-*)
				patch_args+=("$1")
				shift
				;;
			*)
				break
				;;
		esac
	done

	patch_file="$1"
	if [[ -z "$patch_file" || ! -f "$patch_file" ]]; then
		echo "Missing patch file: $patch_file" >&2
		return 1
	fi

	if patch --dry-run "${patch_args[@]}" -i "$patch_file" >/dev/null 2>&1; then
		patch --forward "${patch_args[@]}" -i "$patch_file"
		return $?
	fi

	if patch --dry-run --reverse "${patch_args[@]}" -i "$patch_file" >/dev/null 2>&1; then
		return 0
	fi

	echo "Patch is neither applicable nor already applied: $patch_file" >&2
	return 1
}

eval $*
